# Note: All the variables to this image are optional.
# See README for more information.
# To use, copy this file to 'kokoro.env' and uncomment/set your values.

# Default voice for speech synthesis (default: af_heart)
# - American English: af_heart, af_aoede, af_bella, af_jessica, af_kore,
#     af_nicole, af_nova, af_river, af_sarah, af_sky, af_alloy,
#     am_adam, am_michael, am_echo, am_eric, am_fenrir, am_liam,
#     am_onyx, am_puck, am_santa
# - British English:  bf_emma, bf_isabella, bf_alice, bf_lily,
#     bm_george, bm_lewis, bm_daniel, bm_fable
# - Japanese:         jf_alpha, jf_gongitsune, jf_nezumi, jf_tebukuro, jm_kumo
# - Mandarin Chinese: zf_xiaobei, zf_xiaoni, zf_xiaoxiao, zf_xiaoyi,
#     zm_yunjian, zm_yunxi, zm_yunxia, zm_yunyang
# - Spanish:          ef_dora, em_alex, em_santa
# - French:           ff_siwis
# - Hindi:            hf_alpha, hf_beta, hm_omega, hm_psi
# - Italian:          if_sara, im_nicola
# - Brazilian Pt:     pf_dora, pm_alex, pm_santa
# - OpenAI voice aliases also accepted: alloy, echo, fable, onyx, nova, shimmer,
#     ash, coral, sage, verse
# - Individual requests can override this default using the 'voice' field.
# - Run 'docker exec kokoro kokoro_manage --listvoices' for descriptions of each voice.
# KOKORO_VOICE=af_heart

# Default speech speed (default: 1.0)
# - Range: 0.25 (slowest) to 4.0 (fastest). 1.0 is normal speed.
# - Individual requests can override this default using the 'speed' field.
# KOKORO_SPEED=1.0

# HTTP port for the speech API (default: 8880)
# KOKORO_PORT=8880

# Language pipeline to load (optional)
# - When unset (default), the pipeline is auto-selected from the KOKORO_VOICE prefix.
#   For example, KOKORO_VOICE=af_heart loads the 'a' pipeline automatically.
# - Set explicitly to load a specific language pipeline at startup:
#     a  — American English   b  — British English
#     e  — Spanish            f  — French
#     h  — Hindi              i  — Italian
#     j  — Japanese           p  — Brazilian Portuguese
#     z  — Mandarin Chinese
# - Additional pipelines for other languages are created on demand when a request
#   uses a voice from a different language.
# KOKORO_LANG_CODE=

# Optional API key to require Bearer token authentication on all requests.
# - If not set, the API is open (no authentication required).
# - When set, every request must include: -H "Authorization: Bearer <key>"
# - Keep this secret if you expose the server to the internet.
# KOKORO_API_KEY=

# Log level (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# KOKORO_LOG_LEVEL=INFO

# Local-only mode: disable all HuggingFace model downloads (default: unset)
# - When set to any non-empty value (e.g. true), Kokoro will only use
#   models already present in the /var/lib/kokoro cache volume and will not
#   attempt to contact HuggingFace. Useful for air-gapped or offline deployments.
# - Leave unset (default) to allow automatic model download on first start.
# KOKORO_LOCAL_ONLY=
